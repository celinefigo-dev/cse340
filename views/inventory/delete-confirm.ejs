<section class="form-section">
    <h1>
        <%= title %>
    </h1>
    <p>Please confirm that you want to delete this vehicle. This action cannot be undone.</p>

    <form action="/inv/delete" method="post" class="form-card">
        <input type="hidden" name="inv_id" value="<%= inv_id %>">

        <label for="inv_make">Make</label>
        <input type="text" id="inv_make" value="<%= inv_make %>" readonly>

        <label for="inv_model">Model</label>
        <input type="text" id="inv_model" value="<%= inv_model %>" readonly>

        <label for="inv_year">Year</label>
        <input type="text" id="inv_year" value="<%= inv_year %>" readonly>

        <label for="inv_price">Price</label>
        <input type="text" id="inv_price" value="$<%= Number(inv_price).toLocaleString('en-US') %>" readonly>

        <button type="submit" class="btn">Delete Vehicle</button>
    </form>
</section>