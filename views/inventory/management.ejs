<section class="page-header">
    <h1>Vehicle Management</h1>
    <p>Manage classifications and inventory items from one place.</p>
</section>

<% if (notice) { %>
    <div class="notice">
        <%= notice %>
    </div>
    <% } %>

        <section class="home-content">
            <div class="card">
                <h2>Inventory Tools</h2>
                <p>Use the links below to manage your vehicle records.</p>
                <div class="action-links">
                    <a class="btn" href="/inv/addClassification">Add Classification</a>
                    <a class="btn" href="/inv/addInventory">Add Inventory</a>
                </div>
            </div>

            <div class="card">
                <h2>Edit Inventory</h2>
                <p>Select a classification to view and edit inventory items.</p>
                <form>
                    <label for="classificationList">Choose a classification</label>
                    <%- classificationSelect %>
                </form>
                <div id="inventoryDisplay"></div>
            </div>
        </section>

        <script>
            const classificationList = document.getElementById("classificationList")
            const inventoryDisplay = document.getElementById("inventoryDisplay")

            if (classificationList) {
                classificationList.addEventListener("change", async function () {
                    const classificationId = this.value
                    if (!classificationId) {
                        inventoryDisplay.innerHTML = ""
                        return
                    }

                    try {
                        const response = await fetch(`/inv/getInventory/${classificationId}`)
                        const data = await response.json()

                        if (!data.length) {
                            inventoryDisplay.innerHTML = "<p class='notice'>No inventory found for this classification.</p>"
                            return
                        }

                        let table = `
          <table class="inventory-table">
            <thead>
              <tr>
                <th>Vehicle Name</th>
                <th>Edit</th>
                <th>Delete</th>
              </tr>
            </thead>
            <tbody>
        `

                        data.forEach(item => {
                            table += `
            <tr>
              <td>${item.inv_make} ${item.inv_model}</td>
              <td><a href="/inv/edit/${item.inv_id}">Modify</a></td>
              <td><a href="/inv/delete/${item.inv_id}">Delete</a></td>
            </tr>
          `
                        })

                        table += "</tbody></table>"
                        inventoryDisplay.innerHTML = table
                    } catch (error) {
                        inventoryDisplay.innerHTML = "<p class='notice'>Sorry, there was a problem loading inventory.</p>"
                    }
                })
            }
        </script>