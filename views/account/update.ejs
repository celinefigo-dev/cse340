<section class="form-section">
    <h1>
        <%= title %>
    </h1>

    <% if (notice && notice.length) { %>
        <div class="notice">
            <%= notice[0] %>
        </div>
        <% } %>

            <% if (errors && errors.length) { %>
                <ul class="notice error-list">
                    <% errors.forEach(error=> { %>
                        <li>
                            <%= error.msg %>
                        </li>
                        <% }) %>
                </ul>
                <% } %>

                    <div class="form-card">
                        <h2>Account Update</h2>
                        <form action="/account/update" method="post">
                            <input type="hidden" name="account_id" value="<%= account_id %>">

                            <label for="account_firstname">First Name</label>
                            <input type="text" id="account_firstname" name="account_firstname" required
                                value="<%= account_firstname %>">

                            <label for="account_lastname">Last Name</label>
                            <input type="text" id="account_lastname" name="account_lastname" required
                                value="<%= account_lastname %>">

                            <label for="account_email">Email Address</label>
                            <input type="email" id="account_email" name="account_email" required
                                value="<%= account_email %>">

                            <button type="submit" class="btn">Update Account</button>
                        </form>
                    </div>

                    <div class="form-card">
                        <h2>Change Password</h2>
                        <p>
                            Enter a new password to replace your current password. Password must be at least 12
                            characters and include 1 uppercase letter, 1 number, and 1 special character.
                        </p>

                        <form action="/account/update-password" method="post">
                            <input type="hidden" name="account_id" value="<%= account_id %>">

                            <label for="account_password">New Password</label>
                            <input type="password" id="account_password" name="account_password" required
                                pattern="^(?=.*[A-Z])(?=.*[0-9])(?=.*[!@#$%^&*()_+\-=\[\]{};':&quot;\\|,.<>\/?]).{12,}$">

                            <button type="submit" class="btn">Change Password</button>
                        </form>
                    </div>
</section>