<section class="account-dashboard">
    <h1>Account Management</h1>

    <% if (notice && notice.length) { %>
        <div class="notice">
            <%= notice[0] %>
        </div>
        <% } %>

            <% if (loggedin && accountData) { %>
                <h2>Welcome <%= accountData.account_firstname %>
                </h2>

                <p>
                    <a href="/account/update/<%= accountData.account_id %>">
                        Update Account Information
                    </a>
                </p>

                <% if (accountData.account_type==="Employee" || accountData.account_type==="Admin" ) { %>
                    <h3>Inventory Management</h3>
                    <p>
                        <a href="/inv/">Manage Inventory</a>
                    </p>
                    <% } %>
                        <% } else { %>
                            <div class="account-login-prompt">
                                <h2>Please log in to access your account management area.</h2>
                                <a class="btn" href="/account/login">Go to Login</a>
                            </div>
                            <% } %>
</section>