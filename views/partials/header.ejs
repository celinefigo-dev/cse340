<header id="top-header">
    <span class="siteName">
        <a href="/" title="Return to home page">CSE Motors</a>
    </span>
    <span class="favoriteLink">
        <% if (locals.loggedin && locals.accountData.account_type==='Client' ) { %>
            <a href="/account/favorites" title="View your favorite vehicles">Your Favorites</a>
            <% } %>
    </span>
    <div id="tools">
        <% if (locals.loggedin) { %>
            <a href="/account/" title="Go to account management">Welcome <%= accountData.account_firstname %></a>
            <a href="/account/logout" title="Click to log out">Logout</a>
            <% } else { %>
                <a title="Click to log in" href="/account/login">MY ACCOUNT</a>
                <% } %>
    </div>
</header>